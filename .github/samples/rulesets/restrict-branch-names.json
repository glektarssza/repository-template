{
    "name": "Restrict branch names",
    "target": "branch",
    "enforcement": "active",
    "conditions": {
        "ref_name": {
            "exclude": [
                "~DEFAULT_BRANCH",
                "refs/heads/chore/*",
                "refs/heads/chore/**/*",
                "refs/heads/task/*",
                "refs/heads/task/**/*",
                "refs/heads/feature/*",
                "refs/heads/feature/**/*",
                "refs/heads/hotfix/*",
                "refs/heads/hotfix/**/",
                "refs/heads/hot-fix/*",
                "refs/heads/hot-fix/**/",
                "refs/heads/bugfix/*",
                "refs/heads/bugfix/**/*",
                "refs/heads/bug/*",
                "refs/heads/bug/**/*",
                "refs/heads/bug-fix/*",
                "refs/heads/bug-fix/**/*",
                "refs/heads/bugfix/*",
                "refs/heads/bugfix/**/*",
                "refs/heads/refactor/*",
                "refs/heads/refactor/**/*",
                "refs/heads/release/v*",
                "refs/heads/security/*",
                "refs/heads/security/**/*",
                "refs/heads/dependabot/*",
                "refs/heads/dependabot/**/*"
            ],
            "include": ["~ALL"]
        }
    },
    "rules": [
        {
            "type": "creation"
        }
    ],
    "bypass_actors": []
}
